general {
    interval = 1
    colors   = true
    color_good     = '#9ccfd8'
    color_degraded = '#f6c177'
    color_bad      = '#eb6f92'
}

order += "disk /"
order += "battery 1"
order += "volume master"
order += "tztime local"

volume master {
    format = "VOL: %volume"
    format_muted = "MUTE"
    device = "default"
    mixer = "Master"
}

disk "/" {
    format = "DISK: %avail"
    prefix_type = custom
    low_threshold = 20
    threshold_type = percentage_avail
}

battery 1 {
    format = "BAT: %percentage"
    format_down = ""
    last_full_capacity = true
    integer_battery_capacity = true
    low_threshold = 11
    threshold_type = percentage

    status_chr = "AC"
    status_bat = "BAT"
    status_unk = "UNK"
    status_full = "FULL"
}

tztime local {
    format = "%a, %d-%b/%I:%M %p "
}
